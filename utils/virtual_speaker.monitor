import pyaudio

p = pyaudio.PyAudio()

# Находим monitor виртуального sink
for i in range(p.get_device_count()):
    dev = p.get_device_info_by_index(i)
    if 'Virtual_Speaker' in dev['name'] and 'monitor' in dev['name'].lower():
        device_index = dev['index']
        break

# Записываем с него
stream = p.open(
    format=pyaudio.paInt16,
    channels=2,
    rate=48000,
    input=True,
    input_device_index=device_index,
    frames_per_buffer=1024
)